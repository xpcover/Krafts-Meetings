# --- Vexa Environment ---
# Copy to repo root as .env:  cp deploy/env-example .env
# Then edit the REQUIRED fields below.

# ============================================================================
# REQUIRED — you MUST set these
# ============================================================================

# Transcription service
# Get a key at vexa.ai OR self-host services/transcription-service/ with GPU
TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=your-token

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
WORKFLOW_API_PORT=8060
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================

# Admin
ADMIN_TOKEN=changeme

# Image tag — pre-built from DockerHub by default.
# `make build` writes a local tag to .last-tag which overrides this.
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest


# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres
# For external DB, uncomment:
# REMOTE_DB=true
# DB_HOST=your-postgres-host
# DB_PORT=5432

# Storage (embedded minio by default)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# Local GPU transcription (uncomment to self-host)
# LOCAL_TRANSCRIPTION=true

# TTS uses Piper (local, no API key needed)
# Voice models auto-download from HuggingFace on first use

# Agent API — Claude credentials (optional, for agent-api service)
CLAUDE_CREDENTIALS_PATH=
CLAUDE_JSON_PATH=

# Billing hooks (optional — for hosted service)
# POST_MEETING_HOOKS=https://your-billing-webhook

# ============================================================================
# Krafts Meetings Workflow API — calendar, task extraction, SMTP, Cloudflare edge
# ============================================================================

# Internal Vexa gateway used by workflow-api for bot scheduling/transcripts
VEXA_API_URL=http://api-gateway:8000
VEXA_API_KEY=
WORKFLOW_VEXA_WEBHOOK_SECRET=
WORKFLOW_EDGE_SHARED_SECRET=

# Set to a Fernet key before storing OAuth tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WORKFLOW_ENCRYPTION_KEY=
WORKFLOW_OAUTH_STATE_SECRET=
WORKFLOW_PUBLIC_BASE_URL=http://localhost:8060
WORKFLOW_INIT_DB_ON_STARTUP=true

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Graph / Outlook OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# AI extraction provider for post-meeting summaries/tasks.
# Fast launch default uses OpenAI Responses API. Local providers can be added later.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1

# Reserved for later local LLM fallback.
LOCAL_LLM_URL=

# SMTP delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TLS_MODE=starttls

# Cloudflare edge/control-plane integration
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_WORKER_SHARED_SECRET=
